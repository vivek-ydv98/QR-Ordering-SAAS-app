# ==============================================================================
# QR Restaurant Ordering SaaS — Docker Environment Template
# ==============================================================================
# Copy this to .env.docker and fill in your values.
#   cp .env.docker.example .env.docker
#
# Then start with:
#   docker compose --env-file .env.docker up -d --build
#
# ⚠️  NEVER commit .env.docker to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# Ports (host-side — change if you have conflicts)
# ------------------------------------------------------------------------------
BACKEND_PORT=3001
FRONTEND_PORT=3000

# ------------------------------------------------------------------------------
# Database — External PostgreSQL (Supabase / AWS RDS / self-hosted)
# ------------------------------------------------------------------------------
# DATABASE_URL: Used by Prisma at runtime (can be a pooler endpoint)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# DIRECT_URL: Used by Prisma migrate (must be a direct non-pooled connection)
# If your provider doesn't distinguish, set both to the same value.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# ------------------------------------------------------------------------------
# Authentication
# ------------------------------------------------------------------------------
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET="replace-me-with-a-cryptographically-secure-key"
JWT_EXPIRATION="15m"

# ------------------------------------------------------------------------------
# CORS
# Set to the public URL(s) of your frontend (comma-separated).
# ------------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000

# ------------------------------------------------------------------------------
# Cloudinary — Media Storage (for menu item image uploads)
# ------------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"
CLOUDINARY_URL="cloudinary://your_api_key:your_api_secret@your_cloud_name"

# ------------------------------------------------------------------------------
# Frontend — Next.js public env vars
# These are BAKED INTO the JS bundle at docker build time.
# After changing these you MUST rebuild the frontend image.
# For a Docker-internal setup keep them as localhost references.
# For a real deployment replace with your public API domain.
# ------------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001/v1
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
