    "@types/jest": "^30.0.0",
    "@types/multer": "^2.2.0",
    "@types/node": "^20.3.1",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "prisma": "^6.4.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "typescript": "^5.1.3"
