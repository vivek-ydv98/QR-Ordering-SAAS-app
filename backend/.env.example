# Server Configuration
PORT=3001
NODE_ENV=development

# CORS: Comma-separated list of allowed frontend origins
# DEV → localhost only
ALLOWED_ORIGINS=http://localhost:3000
# PRODUCTION → Replace with your real deployed domain, e.g.:
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# DATABASE_URL: Runtime query execution (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# DIRECT_URL: Direct migrations & schema push
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# Authentication
# Secret used for signing JWT access tokens (generate with: openssl rand -base64 32)
JWT_SECRET="your-super-secret-jwt-key"
JWT_EXPIRATION="15m"

# Third-party Media Storage (Cloudinary for menu image uploads)
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"
