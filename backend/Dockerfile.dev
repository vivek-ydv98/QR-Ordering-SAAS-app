# =============================================================================
# Backend — Development Dockerfile (lightweight, no multi-stage)
# Used only by docker-compose.dev.yml
# =============================================================================
FROM node:20-alpine

RUN apk add --no-cache libc6-compat openssl

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci --legacy-peer-deps

COPY prisma ./prisma
RUN npx prisma generate

COPY . .

EXPOSE 3001 9229

CMD ["npm", "run", "start:dev"]
