# ==============================================================================
# QR RESTAURANT ORDERING SAAS - ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to backend/.env and frontend/.env.local and populate the values.
# ==============================================================================

# ------------------------------------------------------------------------------
# BACKEND SERVICES CONFIGURATION (Save to: backend/.env)
# ------------------------------------------------------------------------------

# 1. API Server Settings
PORT=3001
NODE_ENV=development

# 2. CORS Configurations (Comma-separated list of allowed origins)
# In production, restrict this to your front-facing domains.
ALLOWED_ORIGINS=http://localhost:3000

# 3. Database Credentials (PostgreSQL / Supabase)
# DATABASE_URL: Transaction pooler connection string (PgBouncer/Supavisor port 6543)
DATABASE_URL="postgresql://postgres:[password]@db.[project-id].supabase.co:6543/postgres?pgbouncer=true&connection_limit=10"
# DIRECT_URL: Session-based connection string for executing migrations (port 5432)
DIRECT_URL="postgresql://postgres:[password]@db.[project-id].supabase.co:5432/postgres"

# 4. JWT Authentication Secrets
# Generate a strong 32-byte key using: openssl rand -base64 32
JWT_SECRET="generate-a-cryptographically-secure-key"
JWT_EXPIRATION="15m"

# 5. Cloudinary Storage (For menu item image uploads)
CLOUDINARY_URL="cloudinary://[api_key]:[api_secret]@[cloud_name]"


# ------------------------------------------------------------------------------
# FRONTEND SERVICES CONFIGURATION (Save to: frontend/.env.local)
# ------------------------------------------------------------------------------

# 1. Next.js Target URLs (Point to your local/production API gateway)
NEXT_PUBLIC_API_URL=http://localhost:3001/v1
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
